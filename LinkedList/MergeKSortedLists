Brute Force: T.C. - O(NLOGN), S.C. - O(N)
Approach: Store the lst value in an array and then sort it. Convert the array to a list

class Solution:
    def mergeKLists(self, lists: List[Optional[ListNode]]) -> Optional[ListNode]:
        nodes = []

        for lst in lists:
            while lst:
                nodes.append(lst.val)
                lst = lst.next
        nodes.sort()

        res = ListNode(0)
        curr = res

        for node in nodes:
            curr.next = ListNode(node)
            curr = curr.next
        
        return res.next

Optimal 1 (Merge lists on by one) : T.C. - O(N*K), S.C. - O(1)

Approach: Through recursion send one previous list and the second list, and save it in lists again. In mergelist just save
in increasing order then return list[-1] which give the end of the list.

class Solution:
    def mergeKLists(self, lists: List[Optional[ListNode]]) -> Optional[ListNode]:
        if len(lists) == 0:
            return None

        for i in range(1, len(lists)):
            lists[i] = self.mergeList(lists[i - 1], lists[i])

        return lists[-1]         #end of list

    def mergeList(self, l1, l2):
        dummy = ListNode()
        tail = dummy

        while l1 and l2:
            if l1.val < l2.val:
                tail.next = l1
                l1 = l1.next
            else:
                tail.next = l2
                l2 = l2.next
            tail = tail.next
        if l1:
            tail.next = l1
        if l2:
            tail.next = l2
        return dummy.next

Optimal 2 (Divide and Conquer) : T.C. - O(NLOGK) , S.C. - O(LOGK), time : merge all nodes (n times), logk - two lists at a time (k+k/2+k/4+...)
Approach: Divide the main list from 0 to n-1, then left and right will make calls for each list.

                         Divide(lists,0,2)
                            /      \
                left(lists,0,1)     right(lists,2,2)
                   /      \
    left(lists,0,0)      right(lists,1,1)
                   

class Solution:
    def mergeKLists(self, lists: List[Optional[ListNode]]) -> Optional[ListNode]:
        if not lists or len(lists) == 0:
            return None
        return self.Divide(lists,0,len(lists)-1)
    
    def Divide(self,lists,l,r):
        if l > r:
            return None
        if l == r:
            return lists[l]
        
        mid = l + (r-l) // 2
        left = self.Divide(lists,l,mid)
        right = self.Divide(lists,mid+1,r)

        return self.Conquer(left,right)

    def Conquer(self,l1,l2):
        dummy = ListNode(0)
        curr = dummy
        
        while l1 and l2:
            if l1.val <= l2.val:
               curr.next = l1
               l1 = l1.next
            else:
               curr.next = l2
               l2 = l2.next
            curr = curr.next


        
        if l1:
            curr.next = l1
            l1 = l1.next
        if l2:
            curr.next = l2
            l2 = l2.next
        return dummy.next

