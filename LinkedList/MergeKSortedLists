Brute Force: T.C. - O(NLOGN), S.C. - O(N)
Approach: Store the lst value in an array and then sort it. Convert the array to a list

class Solution:
    def mergeKLists(self, lists: List[Optional[ListNode]]) -> Optional[ListNode]:
        nodes = []

        for lst in lists:
            while lst:
                nodes.append(lst.val)
                lst = lst.next
        nodes.sort()

        res = ListNode(0)
        curr = res

        for node in nodes:
            curr.next = ListNode(node)
            curr = curr.next
        
        return res.next
        
