Brute Force: T.C. - O(N), S.C. - O(N)
Approach: Take an array, store the elements of the linkedlist then with the help of pointers catch the elements at n-1, and n-1 , etc
class Solution:
    def reorderList(self, head: Optional[ListNode]) -> None:
        if not head:
            return

        nodes = []          #array created
        curr = head
        while curr:
            nodes.append(curr)
            curr = curr.next
        
        i, j = 0, len(nodes)-1

        while i < j:
            nodes[i].next = nodes[j]
            i += 1

            if i >= j:
                break
            
            nodes[j].next = nodes[i]
            j -= 1
        nodes[i].next = None

Optimal Sol^n - T.C. - O(N), S.C. - O(1)

class Solution:
    def reorderList(self, head: Optional[ListNode]) -> None:
        #take fast to the end of LL and second to last of the first LL
        #first ll - [1,2], second LL [3,4]

        slow, fast = head, head.next

        while fast and fast.next:
            slow = slow.next
            fast = fast.next.next

        #reverse
        second = slow.next #beg of second ll
        prev = slow.next = None #intially

        while second:
            tmp = second.next
            second.next = prev
            prev = second
            second = tmp

        #merge

        first, second = head, prev

        while second:     #till second ll exists
            tmp1, tmp2 = first.next, second.next
            first.next = second
            second.next = tmp1
            first, second = tmp1, tmp2
