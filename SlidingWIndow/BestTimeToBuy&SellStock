Brute Force: T.C. - O(N^2), S.C. - O(1)

class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        res = 0
        for i in range(len(prices)):
            buy = prices[i]
            for j in range(i+1,len(prices)):
                sell = prices[j]
                res = max(res,sell-buy)
        return res

Optimal (Two Pointer) : T.C. - O(N) , S.C. - O(1)
Approach : I found in brute force we were going through sell-buy (profit) being negative also, in this optimal solution
we have managed that by finding if the sell price is more than the buying price beforehand

class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        l, r = 0,1
        maxP = 0

        while r < len(prices):
            if prices[l] < prices[r]:
                profit = prices[r] - prices[l]
                maxP = max(maxP, profit)
            else:
                l = r
            r += 1

        return maxP
