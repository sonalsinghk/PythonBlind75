1. Brute Force: T.C. - O(NLOGN), S.C.- O(N) - Array used

Approach: Array is used to store the tree nodes then we used sorting and returned k-1 arr 
element

class Solution:
    def kthSmallest(self, root: Optional[TreeNode], k: int) -> int:
        arr = []

        def dfs(node):
            if not node:
                return
            arr.append(node.val)
            dfs(node.left)
            dfs(node.right)
        
        dfs(root)
        arr.sort()
        return arr[k-1]

2. Inorder Traversal : T.C. - O(N), S.C. - O(N)

Approach: Inorder Traversal gives sorted nodes

class Solution:
    def kthSmallest(self, root: Optional[TreeNode], k: int) -> int:
        arr = []

        def dfs(node):
            if not node:
                return

            dfs(node.left)
            arr.append(node.val)
            dfs(node.right)
        
        dfs(root)
        return arr[k-1]

3. Recursive DFS : T.C. - O(H+K), S.C. - O(H)


class Solution:
    def kthSmallest(self, root: Optional[TreeNode], k: int) -> int:
        
        cnt = k
        res = root.val

        def dfs(node):
            nonlocal cnt,res
            if not node:
                return
            
            dfs(node.left)
            if cnt == 0:
                return
            cnt -= 1
            if cnt == 0:
                res = node.val
                return
            dfs(node.right)
        
        dfs(root)
        return res
            
