Brute Force---------------
class Solution:
    def containsDuplicate(self, nums: List[int]) -> bool:
        for i in range(len(nums)):
            for j in range(i+1, len(nums)):
                if(nums[i] == nums[j]):
                    return True
                    break
        return False
T.C. - O(N^2)
S.C - O(1)
        
