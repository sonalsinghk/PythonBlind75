BRUTE FORCE : T.C. - O(N^2), S.C. - O(N)
O/P : TLE

class Solution:
    def productExceptSelf(self, nums: List[int]) -> List[int]:
        prod_list = []
        for i in range(len(nums)):
            prod = 1
            for j in range(len(nums)):
                if(i != j):
                   prod *= nums[j]   
            prod_list.append(prod)

        return prod_list
